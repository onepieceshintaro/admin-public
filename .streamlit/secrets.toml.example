# Streamlit Cloud の [Settings] > [Secrets] にこの内容を貼り付けるか、
# ローカル開発時は `.streamlit/secrets.toml` にコピーして値を入れる。
#
# ⚠️ 本物の secrets.toml は .gitignore で除外されています。コミットしないこと。

# 共有 Supabase DB（CBT/気分/アサーション と同じもの）
DATABASE_URL = "postgresql://USER:PASSWORD@HOST:PORT/DBNAME"

# このダッシュボードのログインパスワード（管理者本人のみが知っていればよい）
ADMIN_PASSWORD = "change-me-to-something-strong"
